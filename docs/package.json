{
  "name": "docs",
  "version": "0.0.2",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "sync:ignix": "node -e \"const fs=require('fs'); const path=require.resolve('@mindfiredigital/ignix-lite/ignix-lite.min.js'); fs.copyFileSync(path,'./static/ignix-lite.min.js')\"",
    "start": "pnpm sync:ignix && docusaurus start",
    "build": "pnpm sync:ignix && docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@docusaurus/core": "3.10.1",
    "@docusaurus/faster": "3.10.1",
    "@docusaurus/preset-classic": "3.10.1",
    "@mdx-js/react": "^3.0.0",
    "@mindfiredigital/ignix-lite": "workspace:*",
    "clsx": "^2.0.0",
    "docusaurus-plugin-sass": "^0.2.6",
    "prism-react-renderer": "^2.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sass": "^1.99.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.10.1",
    "@docusaurus/tsconfig": "3.10.1",
    "@docusaurus/types": "3.10.1",
    "@types/react": "^19.0.0",
    "typescript": "~6.0.2"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=20.0"
  }
}
