{
  "name": "ignix-lite",
  "version": "1.0.0",
  "type": "module",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "node scripts/resolve-workspace-deps.mjs && changeset publish",
    "lint": "turbo run lint",
    "test": "vitest",
    "format": "turbo run format",
    "a2ui-demo": "pnpm --filter @mindfiredigital/ignix-lite-a2ui-demo dev",
    "prepare": "husky",
    "typecheck": "tsc -b",
    "size": "node scripts/size.js",
    "storybook": "storybook dev --config-dir storybook/.storybook",
    "build-storybook": "storybook build --config-dir storybook/.storybook",
    "changeset:autogenerate": "node .github/changeset-autogenerate.mjs",
    "cy:run": "cypress run",
    "cy:open": "cypress open",
    "merge-reports": "npx mochawesome-merge cypress/reports/*.json > cypress/reports/report.json",
    "generate-report": "npx marge cypress/reports/report.json -f report -o cypress/reports",
    "test:report": "npm run cy:run && npm run merge-reports && npm run generate-report"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/register": "^7.29.3",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@storybook/addon-a11y": "^8.6.17",
    "@storybook/addon-essentials": "8.6.17",
    "@storybook/html": "8.6.17",
    "@storybook/html-vite": "8.6.17",
    "@types/node": "^25.8.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "clean-css-cli": "^5.6.3",
    "commitlint": "^20.5.0",
    "cypress": "^15.15.0",
    "cypress-multi-reporters": "^2.0.5",
    "eslint": "^10.2.0",
    "eslint-plugin-storybook": "10.3.5",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "mocha-junit-reporter": "^2.2.1",
    "prettier": "^3.8.3",
    "sass": "^1.99.0",
    "scss": "^0.2.4",
    "storybook": "8.6.17",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "turbo": "^2.9.6",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "puppeteer",
      "cypress"
    ]
  }
}