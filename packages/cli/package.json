{
  "name": "@mindfiredigital/ignix-lite-cli",
  "version": "1.6.6",
  "description": "CLI tool for Ignix-Lite project scaffolding, validation, and theming",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ignix-lite": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint . --no-error-on-unmatched-pattern",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@mindfiredigital/ignix-lite-engine": "workspace:^",
    "@mindfiredigital/ignix-lite-mcp": "workspace:^",
    "commander": "^13.1.0",
    "node-html-parser": "^7.1.0",
    "ora": "^9.4.0",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.5.1",
    "typescript": "^5.4.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
