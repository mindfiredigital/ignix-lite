{
  "name": "@mindfiredigital/ignix-lite",
  "version": "1.0.1",
  "description": "Browser-native, agent-optimized UI CSS library",
  "main": "ignix-lite.min.css",
  "style": "ignix-lite.min.css",
  "files": [
    "ignix-lite.scss",
    "ignix-lite.min.css",
    "ignix-lite.min.js",
    "README.md"
  ],
  "scripts": {
    "build": "vite build && node ../../scripts/postbuild.js",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint . --no-error-on-unmatched-pattern",
    "format": "prettier --write ."
  },
  "keywords": [
    "css",
    "ui",
    "design-system",
    "ignix-lite"
  ],
  "author": "Mindfire Digital",
  "license": "MIT",
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "devDependencies": {
    "eslint": "^10.2.0",
    "prettier": "^3.8.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.4"
  }
}
