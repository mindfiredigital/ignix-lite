{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "strict": true,
        "outDir": "./dist",
        "composite": false
    },
    "include": [
        "src/**/*",
        "src/**/*.json"
    ]
