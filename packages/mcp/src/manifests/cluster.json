{
  "component": "cluster",
  "version": "2.0",
  "description": "Wrapping inline group for tags, badges, chips, or buttons. Children wrap naturally when they exceed the container width.",

  "element": "div",

  "emmet": "div[data-cluster=sm]>(mark[data-intent=primary]*3)",

  "props": {
    "data-cluster": {
      "type": "string",
      "values": ["xs", "sm", "md", "lg", "xl"],
      "default": "sm",
      "agent_hint": "Controls gap between clustered items."
    }
  },

  "states": [],

  "slots": {
    "item": {
      "required": false,
      "element": ["mark", "span", "button", "a", "label"],
      "agent_hint": "Inline items to cluster together: badges, tags, buttons."
    }
  },

  "child_props": {},

  "forbidden_props": ["class"],

  "required_props": ["data-cluster"],

  "required_slots": [],

  "required_wrapper": null,

  "do": [
    "Use for badge groups, tag lists, filter chips",
    "Use mark[data-intent] for colored badges inside cluster",
    "Use data-cluster=sm for tight tag groups",
    "Use data-cluster=md for button groups"
  ],

  "dont": [
    "Do not use class attribute",
    "Do not use for block-level stacking — use data-stack instead",
    "Do not mix block and inline children"
  ],

  "examples": [
    {
      "label": "Badge cluster",
      "emmet": "div[data-cluster=sm]>(mark[data-intent=primary]{React})+(mark[data-intent=success]{TypeScript})+(mark[data-intent=warning]{Beta})",
      "html": "<div data-cluster=\"sm\"><mark data-intent=\"primary\">React</mark><mark data-intent=\"success\">TypeScript</mark><mark data-intent=\"warning\">Beta</mark></div>"
    },
    {
      "label": "Action button group",
      "emmet": "div[data-cluster=md]>(button[data-intent=primary]{Save})+(button[data-intent=ghost]{Cancel})+(button[data-intent=danger]{Delete})",
      "html": "<div data-cluster=\"md\"><button data-intent=\"primary\">Save</button><button data-intent=\"ghost\">Cancel</button><button data-intent=\"danger\">Delete</button></div>"
    },
    {
      "label": "Tag filter list",
      "emmet": "div[data-cluster=xs]>(mark*5)",
      "html": "<div data-cluster=\"xs\"><mark>Design</mark><mark>Dev</mark><mark>UX</mark><mark>API</mark><mark>CSS</mark></div>"
    }
  ]
}
