{
  "component": "stack",
  "version": "2.0",
  "description": "Stacks children vertically with a controlled gap. Use for form fields, page sections, or any vertical sequence of elements.",

  "element": "div",

  "emmet": "div[data-stack=md]>p*3",

  "props": {
    "data-stack": {
      "type": "string",
      "values": ["xs", "sm", "md", "lg", "xl"],
      "default": "md",
      "agent_hint": "Controls vertical gap between stacked children."
    }
  },

  "states": [],

  "slots": {
    "item": {
      "required": false,
      "element": ["p", "div", "section", "article", "header", "footer", "form", "ul", "h1", "h2", "h3"],
      "agent_hint": "Any block-level child to be stacked vertically."
    }
  },

  "child_props": {},

  "forbidden_props": ["class"],

  "required_props": ["data-stack"],

  "required_slots": [],

  "required_wrapper": null,

  "do": [
    "Use for vertical sequences: form fields, sections, lists",
    "Use semantic parent elements like main, section, form",
    "Combine with data-center for centered stacked content"
  ],

  "dont": [
    "Do not use class attribute",
    "Do not use inline margin/padding to create spacing — use data-stack gap instead",
    "Do not nest data-stack inside data-stack unless semantically needed"
  ],

  "examples": [
    {
      "label": "Basic stack",
      "emmet": "div[data-stack=md]>p*3",
      "html": "<div data-stack=\"md\"><p>Item 1</p><p>Item 2</p><p>Item 3</p></div>"
    },
    {
      "label": "Form fields stacked",
      "emmet": "form[data-stack=lg]>(label>input[type=text])+(label>input[type=email])+button[type=submit]{Submit}",
      "html": "<form data-stack=\"lg\"><label>Name<input type=\"text\"></label><label>Email<input type=\"email\"></label><button type=\"submit\">Submit</button></form>"
    },
    {
      "label": "Page sections stacked",
      "emmet": "main[data-stack=xl]>section*3",
      "html": "<main data-stack=\"xl\"><section>Section 1</section><section>Section 2</section><section>Section 3</section></main>"
    }
  ]
}
