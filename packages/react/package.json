{
  "name": "@ignix-lite/react",
  "version": "1.0.0",

  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",

  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },

  "scripts": {
    "build": "tsup",
    "build:types": "tsc -p tsconfig.json",
    "build:all": "pnpm build && pnpm build:types"
  },

  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },

  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsup": "^8.5.1",
    "typescript": "^5.4.5"
  }
}